[submodule ".config/nvim"]
	path = .config/nvim
	url = ../nvim
        branch = main

[submodule ".config/emacs"]
	path = .config/emacs
	url = ../emacs
        branch = main

[submodule ".config/.vscodium"]
	path = .config/.vscodium
	url = ../.vscodium
        branch = main

[submodule ".config/opencode"]
	path = .config/opencode
	url = ../opencode
        branch = main

[submodule ".config/zed"]
	path = .config/zed
	url = ssh://git@codeberg.org/v_raton/zed.git
	branch = main
